                        fill="currentColor" fill-rule="evenodd"></path>
                </svg>
            </div>
            <h2 class="text-[#131811] dark:text-white text-lg font-bold leading-tight tracking-[-0.015em]">TaskFlow</h2>
        <button
            class="hidden sm:flex cursor-pointer items-center justify-center rounded-full h-9 px-5 bg-transparent border border-white/20 hover:bg-white/10 text-white text-sm font-bold transition-all">
            <span><a href="/">Go Home</a></span>
        </button>
        </div>
        
        <button
            class="flex min-w-[84px] max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-xl h-10 px-4 bg-primary text-[#131811] text-sm font-bold leading-normal tracking-[0.015em] transition-transform hover:scale-105">
            <a href="/login">Log In</a>
        </button>
    </header>
    <!-- Main Content -->
    <main class="flex-1 flex items-center justify-center p-4 lg:p-8">
        <div class="w-full max-w-[1200px] h-full grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
            <!-- Left Side: Illustration & Branding -->
            <div class="hidden lg:flex flex-col gap-6 relative">
                <div class="rounded-2xl overflow-hidden shadow-2xl relative aspect-[4/3] group">
                    <div
                        class="absolute inset-0 bg-gradient-to-tr from-[#131811]/80 via-transparent to-[#46ec13]/10 z-10 pointer-events-none">
                    </div>
                    <div class="w-full h-full bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
                        data-alt="Abstract 3D rendering of floating geometric shapes in dark mode with neon green accents representing productivity"
                        style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuB0r5NsKJyLw7LJFbXfYYehkgNfU7JD_gR9F8DBl3T991o3AFb_Yz6NBl2HTqrAvZKtN27P7jK37hntqI1s3UnBLPsdsoOeN7GpX5tA6ubdTJOCSmyVPvafsD46SDW9HZ4MBefLgZL47_RcUL0fAnCX_E7doPFeq2acsVtsoyYL0rn2fiLYd-S2F9wPDLuE63MolmNR1SgrqjghKAMxrr5PLgcXbPXRx4Ie3CXA5KWa6xLZt9h-SwyIfO3O3rz-HCHNhcPYh-7SkIQ');">
                    </div>
                </div>
                <div class="space-y-4">
                    <h3 class="text-3xl font-bold text-white tracking-tight">Focus on what matters.</h3>
                    <p class="text-[#a3b99d] text-lg leading-relaxed max-w-md">Join thousands of users who are
                        organizing their life and work with TaskFlow. Experience the new standard of productivity.</p>
                    <div class="flex items-center gap-4 pt-2">
                        <div class="flex -space-x-3">
                            <img alt="User avatar 1" class="w-10 h-10 rounded-full border-2 border-[#142210]"
                                data-alt="User profile picture"
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuAQzDupT8iML1yJ5b8A8-oEs3F3dRbTtIXBwYhFs96PYtw_rRjHi7ZD5QNr5KEAcFu_e_tzYTVESZVcvJbXD2p3q4HUfgCBIzBQe8jAQER39FReyLDqXuyIusaSdu94J7TxzyUipCpyJbOwjaDo16TDFviszFdpNhm0b0NPHB-fjkI7tCh43P6ld1qDtbH8t10SQZj4Wpe0L4gOkOl3BdFY-Se2bpKWRfa3HNgxNrXrScJHgeT63CG6sqEQp3q8vOLoUMJVXxmS23Q" />
                            <img alt="User avatar 2" class="w-10 h-10 rounded-full border-2 border-[#142210]"
                                data-alt="User profile picture"
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuB1Ri3I43VnUsNdvxzCcQoonkY6ygxy_6Rlkg40qOLvRYp3IJw1zWvzaesYdLBAdtcEE7e7nCCLQTpt4pk2U2oZV-03P6Vcdi-uGM_puSHR0F6x8m155KaqEnDnCavxqZoZwPRms0gxO7duvojRX9yr7BydNOSTg5Hc9NMavTiy_7O6Ebp_-FSxGHNRQLvmGsnJMdAkOC8k2GZ1a3IBlnp6uVGkl8iPhMq7u5VabK1j3Xe6ki8ysl5QOKBVFEtdIgkLmQuPr1oxMgA" />
                            <img alt="User avatar 3" class="w-10 h-10 rounded-full border-2 border-[#142210]"
                                data-alt="User profile picture"
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuAlqWmWWaelo_WbhzmlWKnXl_mjTtACW5HwfRWhOSJXt3uoBEBeItqphEJbmMGg8aoW8LThpmZTnjtNvUHdl8EXpKnzLAvYhJqpjt7iQCOSkXiAVfeqK0vBtoE5Ty-reh1kWvowzLVT7fcxDagqdUdpcWZUNlg3IIKviqarQGipj1rIp5sHon3_ad5gmkfEOwbA9psravZw9yqyFPlR9-BqWWZG75o621jkoGOb9TaLtQyWsYLmxhzR5GymYAEjaG5zUi0ai1-G_i8" />
                        </div>
                        <p class="text-sm font-medium text-white">Join 10k+ productive users</p>
                    </div>
                </div>
            </div>
            <!-- Right Side: Registration Form -->
            <div class="w-full max-w-md mx-auto">
                <div
                    class="bg-white dark:bg-[#1c2918] rounded-xl shadow-lg border border-[#e0e0e0] dark:border-[#2c3928] p-6 sm:p-8">
                    <!-- Header -->
                    <div class="mb-8">
                        <h1 class="text-[#131811] dark:text-white tracking-tight text-3xl font-bold leading-tight mb-2">
                            Create Account</h1>
                        <p class="text-[#6b7280] dark:text-[#a3b99d] text-base font-normal leading-normal">Start getting
                            things done today.</p>
                    </div>
                    <!-- Form -->
                    <form action="/register" method="POST" class="flex flex-col gap-5" enctype="multipart/form-data">
                        <!-- Full Name -->
                        <div class="flex flex-col gap-2">
                            <label class="text-[#131811] dark:text-white text-sm font-medium leading-normal">Full
                                Name</label>
                            <div class="relative flex items-center group">
                                <input
                                    class="form-input w-full rounded-xl border border-[#e5e7eb] dark:border-[#41543b] bg-transparent dark:bg-[#142210] h-12 px-4 pl-11 text-[#131811] dark:text-white placeholder:text-[#9ca3af] dark:placeholder:text-[#5c6b57] focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
                                    placeholder="John Doe" type="text" name="name" />
                                <span
                                    class="material-symbols-outlined absolute left-3 text-[#9ca3af] dark:text-[#5c6b57] pointer-events-none group-focus-within:text-primary transition-colors">person</span>
                            </div>
                        </div>
                        <!-- Email -->
                        <div class="flex flex-col gap-2">
                            <label class="text-[#131811] dark:text-white text-sm font-medium leading-normal">Email
                                Address</label>
                            <div class="relative flex items-center group">
                                <input
                                    class="form-input w-full rounded-xl border border-[#e5e7eb] dark:border-[#41543b] bg-transparent dark:bg-[#142210] h-12 px-4 pl-11 text-[#131811] dark:text-white placeholder:text-[#9ca3af] dark:placeholder:text-[#5c6b57] focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
                                    placeholder="name@example.com" type="email" name="email" />
                                <span
                                    class="material-symbols-outlined absolute left-3 text-[#9ca3af] dark:text-[#5c6b57] pointer-events-none group-focus-within:text-primary transition-colors">mail</span>
                            </div>
                        </div>
                        <!-- Password -->
                        <div class="flex flex-col gap-2">
                            <label
                                class="text-[#131811] dark:text-white text-sm font-medium leading-normal">Password</label>
                            <div class="relative flex items-center group">
                                <input
                                    class="form-input w-full rounded-xl border border-[#e5e7eb] dark:border-[#41543b] bg-transparent dark:bg-[#142210] h-12 px-4 pl-11 pr-11 text-[#131811] dark:text-white placeholder:text-[#9ca3af] dark:placeholder:text-[#5c6b57] focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
                                    placeholder="••••••••" type="password" name="password" />
                                <span
                                    class="material-symbols-outlined absolute left-3 text-[#9ca3af] dark:text-[#5c6b57] pointer-events-none group-focus-within:text-primary transition-colors">lock</span>

                            </div>
                        </div>

                        <!--profile pic  -->
                        <div class="flex flex-col gap-2 mt-1">
                            <label class="text-[#131811] dark:text-white text-sm font-medium">
                                Profile Picture
                            </label>

                            <div class="relative flex items-center group">
                                <input type="file" name="pic" class="form-input w-full rounded-xl border border-[#e5e7eb] dark:border-[#41543b]
            bg-transparent dark:bg-[#142210] h-12 px-4 pl-11 text-[#131811]
            dark:text-white placeholder:text-[#9ca3af]
            dark:placeholder:text-[#5c6b57] focus:border-primary
            focus:ring-1 focus:ring-primary transition-colors file:hidden" />

                                <span class="material-symbols-outlined absolute left-3 text-[#9ca3af]
            dark:text-[#5c6b57] pointer-events-none
            group-focus-within:text-primary transition-colors">
                                    image
                                </span>
                            </div>
                        </div>

                        <!-- Terms Checkbox -->
                        <div class="flex items-start gap-3 mt-1">
                            <div class="flex items-center h-5">
                                <input
                                    class="w-5 h-5 border border-[#41543b] rounded bg-[#142210] text-primary focus:ring-primary focus:ring-offset-[#1c2918]"
                                    id="terms" type="checkbox" />
                            </div>
                            <label class="text-sm font-normal text-[#6b7280] dark:text-[#a3b99d]" for="terms">
                                I agree to the <a class="text-primary hover:underline" href="#">Terms of Service</a> and
                                <a class="text-primary hover:underline" href="#">Privacy Policy</a>.
                            </label>
                        </div>
                        <!-- Submit Button -->
                        <button type="submit"
                            class="w-full flex items-center justify-center rounded-xl h-12 px-6 bg-primary hover:bg-[#3bd60d] text-[#131811] text-base font-bold leading-normal tracking-[0.015em] transition-all duration-200 mt-2 shadow-[0_0_15px_rgba(70,236,19,0.2)] hover:shadow-[0_0_25px_rgba(70,236,19,0.4)]">
                            Create Account
                        </button>
                    </form>
                    <!-- Divider -->
                    <div class="relative flex py-6 items-center">
                        <div class="flex-grow border-t border-[#e0e0e0] dark:border-[#2c3928]"></div>
                        <span class="flex-shrink-0 mx-4 text-xs font-medium text-[#9ca3af] dark:text-[#5c6b57]">OR
                            REGISTER WITH</span>
                        <div class="flex-grow border-t border-[#e0e0e0] dark:border-[#2c3928]"></div>
                    </div>
                    <!-- Social Buttons -->
                    <div class="flex gap-4">
                        <button
                            class="flex-1 flex items-center justify-center gap-2 h-10 rounded-lg border border-[#e0e0e0] dark:border-[#2c3928] hover:bg-gray-50 dark:hover:bg-[#2c3928] transition-colors">
                            <svg class="w-5 h-5" fill="none" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path
                                    d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                    fill="#4285F4"></path>
                                <path
                                    d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                    fill="#34A853"></path>
                                <path
                                    d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                    fill="#FBBC05"></path>
                                <path
                                    d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                    fill="#EA4335"></path>
                            </svg>
                        </button>
                        <button
                            class="flex-1 flex items-center justify-center gap-2 h-10 rounded-lg border border-[#e0e0e0] dark:border-[#2c3928] hover:bg-gray-50 dark:hover:bg-[#2c3928] transition-colors text-[#131811] dark:text-white">
                            <svg class="w-5 h-5 fill-current" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path
                                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z">
                                </path>
                            </svg>
                        </button>
                    </div>
                    <!-- Footer Link -->
                    <div class="mt-8 text-center">
                        <p class="text-sm font-normal text-[#6b7280] dark:text-[#a3b99d]">
                            Already have an account?
                            <a class="text-[#131811] dark:text-white font-bold hover:text-primary transition-colors"
                                href="/login">Log in</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>

</html>