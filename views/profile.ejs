<!DOCTYPE html>

<html class="dark" lang="en">

<% -include("./partials/head") %>

<body class="bg-background-light dark:bg-background-dark text-[#111418] dark:text-white font-display overflow-x-hidden">
    <div class="relative flex h-screen w-full bg-background-light dark:bg-background-dark overflow-hidden">
        <!-- Sidebar Navigation -->

        <%- include('./partials/sidebar') %>

            <!-- Main Content Area -->
            <main
                class="flex-1 h-full overflow-y-auto bg-white dark:bg-[#131811] rounded-tl-[2.5rem] shadow-[-10px_-10px_30px_rgba(0,0,0,0.2)] border-l border-gray-100 dark:border-[#22301e]">
                <div class="max-w-[1200px] mx-auto p-6 md:p-10 lg:p-14">
                    <!-- Page Heading -->
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-10">
                        <div>
                            <h2
                                class="text-3xl md:text-4xl font-black tracking-tight text-[#111418] dark:text-white mb-2">
                                My Profile</h2>
                            <p class="text-[#637588] dark:text-[#a3b99d] text-base font-medium">Manage your account
                                settings and preferences.</p>
                        </div>
                        <div class="flex gap-2">
                            <button
                                class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 dark:bg-[#2c3928] text-[#111418] dark:text-white hover:bg-gray-200 dark:hover:bg-[#3a4b35] transition-colors">
                                <span class="material-symbols-outlined">notifications</span>
                            </button>
                        </div>
                    </div>
                    <!-- Profile Header Card -->
                    <section class="mb-8">
                        <div class="bg-gray-50 dark:bg-[#1e2a1b] rounded-3xl p-6 md:p-8 shadow-sm">
                            <div class="flex flex-col md:flex-row items-center md:items-start gap-6 md:gap-8">
                                <div class="relative group">
                                    <img src="<%= pic %>" alt="profile pic" class="w-32 h-32 rounded-full object-cover">
                                    <!-- <div class="w-32 h-32 md:w-40 md:h-40 rounded-full border-4 border-white dark:border-[#2c3928] shadow-lg bg-cover bg-center overflow-hidden"
                                        data-alt="Large profile picture of Alex Sterling"
                                        style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDLTk8yQuAsHqXcur2yTt3HhDR6-0dIJgqQow0_W9AQgbKoY3y5K1mCvKpIYaq4DbeLEh1yS1rlq8qT_7mApjr7U3HwMSJmItOGAb73wcF7xAsAlaF-AFbFnhl55X_BKTob07vTjpHYCljUU9Btu1QxSmpv32oAUkNp3o8Nl31gszau_zhA2ipn3Izpo9kbVeayj9AYd0qKxl8zkJzWjI3wH7BNimo7v39uB3uXXbZnfyIxfhfD2Vv_oqFpQyEHD5dQ8WuErDCBZ9E');">
                                    </div> -->
                                
                                </div>
                                <div
                                    class="flex-1 flex flex-col items-center md:items-start text-center md:text-left pt-2">
                                    <h3 class="text-2xl md:text-3xl font-bold text-[#111418] dark:text-white mb-1">
                                        <%= username %></h3>
                                    <p class="text-[#637588] dark:text-[#a3b99d] text-lg font-medium mb-4">
                                        <%= email %> </p>
                                  
                                    <button
                                        class="flex items-center gap-2 px-6 py-2.5 bg-primary text-[#0d2a04] font-bold rounded-full hover:bg-[#3be00b] transition-all hover:shadow-[0_0_15px_rgba(70,236,19,0.4)] active:scale-95">
                                        <span class="material-symbols-outlined text-xl">edit</span>
                                        <a href="/editprofile">Edit Details</a>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </section>
                    <!-- Statistics Grid -->
                    <section class="mb-10">
                        <h4 class="text-lg font-bold text-[#111418] dark:text-white mb-4 ml-2">Performance Overview</h4>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div
                                class="bg-gray-50 dark:bg-[#1e2a1b] p-6 rounded-2xl flex flex-col gap-1 border border-transparent hover:border-primary/30 transition-colors group">
                                <div class="flex justify-between items-start mb-2">
                                    <div
                                        class="p-2 rounded-full bg-green-100 dark:bg-[#2c3928] text-primary group-hover:bg-primary group-hover:text-[#0d2a04] transition-colors">
                                        <span class="material-symbols-outlined">check_circle</span>
                                    </div>
                                </div>
                                <p class="text-3xl font-black text-[#111418] dark:text-white tracking-tight"><%= completedTasks %></p>
                                <p class="text-sm font-medium text-[#637588] dark:text-[#a3b99d]">Tasks Completed</p>
                            </div>
                            <div
                                class="bg-gray-50 dark:bg-[#1e2a1b] p-6 rounded-2xl flex flex-col gap-1 border border-transparent hover:border-yellow-500/30 transition-colors group">
                                <div class="flex justify-between items-start mb-2">
                                    <div
                                        class="p-2 rounded-full bg-yellow-100 dark:bg-[#393528] text-yellow-600 dark:text-yellow-400 group-hover:bg-yellow-500 group-hover:text-white transition-colors">
                                        <span class="material-symbols-outlined">pending_actions</span>
                                    </div>
                                </div>
                                <p class="text-3xl font-black text-[#111418] dark:text-white tracking-tight"><%= pendingTasks %></p>
                                <p class="text-sm font-medium text-[#637588] dark:text-[#a3b99d]">Pending Tasks</p>
                            </div>
                            <div
                                class="bg-gray-50 dark:bg-[#1e2a1b] p-6 rounded-2xl flex flex-col gap-1 border border-transparent hover:border-blue-500/30 transition-colors group">
                                <div class="flex justify-between items-start mb-2">
                                    <div
                                        class="p-2 rounded-full bg-blue-100 dark:bg-[#283239] text-blue-600 dark:text-blue-400 group-hover:bg-blue-500 group-hover:text-white transition-colors">
                                        <span class="material-symbols-outlined">trending_up</span>
                                    </div>
                                </div>
                                <p class="text-3xl font-black text-[#111418] dark:text-white tracking-tight"><%= priorityTasks %></p>
                                <p class="text-sm font-medium text-[#637588] dark:text-[#a3b99d]">Priority Tasks</p>
                            </div>
                        </div>
                    </section>
                    <!-- Additional Settings / Info -->
                     <div
                                    class="lg:col-span-2 bg-surface-dark rounded-xl p-6 border border-white/5 flex flex-col">
                                    <div class="flex items-center justify-between mb-6">
                                        <div>
                                            <h3 class="text-lg font-bold text-white">Task Velocity</h3>
                                            <p class="text-sm text-text-secondary">Completion rate over last 7 days</p>
                                        </div>
                                        <button
                                            class="p-2 text-text-secondary hover:text-white rounded-lg hover:bg-background-dark transition-colors">
                                            <span class="material-symbols-outlined">more_horiz</span>
                                        </button>
                                    </div>
                                    <div class="flex-1 w-full relative min-h-[250px] flex items-end justify-center">
                                        <!-- Chart SVG -->
                                        <svg class="w-full h-full" fill="none" preserveaspectratio="none"
                                            viewbox="0 0 478 150" xmlns="http://www.w3.org/2000/svg">
                                            <defs>
                                                <lineargradient gradientunits="userSpaceOnUse" id="paint0_linear"
                                                    x1="239" x2="239" y1="0" y2="150">
                                                    <stop stop-color="#46ec13" stop-opacity="0.2"></stop>
                                                    <stop offset="1" stop-color="#46ec13" stop-opacity="0"></stop>
                                                </lineargradient>
                                            </defs>
                                            <path
                                                d="M0 110C20 110 40 40 60 40C80 40 100 90 120 90C140 90 160 30 180 30C200 30 220 70 240 70C260 70 280 50 300 50C320 50 340 120 360 120C380 120 400 20 420 20C440 20 460 100 478 100V150H0V110Z"
                                                fill="url(#paint0_linear)"></path>
                                            <path
                                                d="M0 110C20 110 40 40 60 40C80 40 100 90 120 90C140 90 160 30 180 30C200 30 220 70 240 70C260 70 280 50 300 50C320 50 340 120 360 120C380 120 400 20 420 20C440 20 460 100 478 100"
                                                stroke="#46ec13" stroke-linecap="round" stroke-linejoin="round"
                                                stroke-width="3"></path>
                                            <!-- Data Points -->
                                            <circle cx="60" cy="40" fill="#142210" r="4" stroke="#46ec13"
                                                stroke-width="2">
                                            </circle>
                                            <circle cx="180" cy="30" fill="#142210" r="4" stroke="#46ec13"
                                                stroke-width="2">
                                            </circle>
                                            <circle cx="300" cy="50" fill="#142210" r="4" stroke="#46ec13"
                                                stroke-width="2">
                                            </circle>
                                            <circle cx="420" cy="20" fill="#142210" r="4" stroke="#46ec13"
                                                stroke-width="2">
                                            </circle>
                                        </svg>
                                    </div>
                                    <div class="flex justify-between mt-4 px-2">
                                        <span class="text-xs font-bold text-text-secondary uppercase">Mon</span>
                                        <span class="text-xs font-bold text-text-secondary uppercase">Tue</span>
                                        <span class="text-xs font-bold text-text-secondary uppercase">Wed</span>
                                        <span class="text-xs font-bold text-text-secondary uppercase">Thu</span>
                                        <span class="text-xs font-bold text-text-secondary uppercase">Fri</span>
                                        <span class="text-xs font-bold text-text-secondary uppercase">Sat</span>
                                        <span class="text-xs font-bold text-text-secondary uppercase">Sun</span>
                                    </div>
                                </div>

                </div>
                <script src="/script.js"></script>
            </main>
    </div>
</body>

</html>