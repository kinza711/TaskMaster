                                    class="form-input flex w-full rounded-full bg-[#142210] border border-[#2c3928] focus:border-primary focus:ring-1 focus:ring-primary h-14 pl-12 pr-4 text-white placeholder-[#5c6b55] transition-all"
                                    placeholder="••••••••" type="password" />
                            </div>
                        </label>
                    </div> -->

                            <!-- Action Buttons -->
                            <div class="flex flex-col-reverse sm:flex-row gap-4 pt-4 mt-4 border-t border-[#2c3928]">
                                <button
                                    class="flex-1 sm:flex-none px-8 h-12 rounded-full border border-[#41543b] text-white font-bold hover:bg-[#2c3928] transition-colors"
                                    type="button">
                                    <a href="/profile">Cancel</a>
                                </button>
                                <button
                                    class="flex-1 sm:flex-none px-8 h-12 rounded-full bg-primary text-black font-bold shadow-[0_0_20px_rgba(70,236,19,0.3)] hover:shadow-[0_0_30px_rgba(70,236,19,0.5)] hover:bg-[#3bdb0f] transition-all flex items-center justify-center gap-2"
                                    type="submit">
                                    <span class="material-symbols-outlined">save</span>
                                    Save Changes
                                </button>
                            </div>
                        </form>

                    </div>
                </div>
            </main>

            <script src="/script.js"></script>
    </body>

</html>