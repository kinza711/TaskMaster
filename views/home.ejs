<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>TaskMaster - Modern Task Management</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&amp;display=swap" rel="stylesheet" />
    <!-- Material Symbols -->
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Theme Configuration -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#46ec13",
                        "background-light": "#f6f8f6",
                        "background-dark": "#0f172a", /* Adjusted to slate-900 for better gradient blending */
                        "surface-dark": "#1e293b",
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"],
                        "sans": ["Manrope", "sans-serif"],
                    },
                    borderRadius: { "DEFAULT": "1rem", "lg": "1.5rem", "xl": "2rem", "2xl": "3rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Manrope', sans-serif;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .hero-gradient {
            background: radial-gradient(circle at 50% 0%, rgba(79, 70, 229, 0.15) 0%, rgba(15, 23, 42, 0) 50%),
                linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #172554 100%);
        }

        .text-gradient {
            background: linear-gradient(to right, #ffffff, #a5b4fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>

<body
    class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-white overflow-x-hidden selection:bg-primary selection:text-black">
    <!-- Top Navigation -->
    <div class="fixed top-0 left-0 right-0 z-50 px-4 pt-4 pb-2">
        <div class="layout-container flex justify-center w-full">
            <header
                class="glass-panel flex items-center justify-between whitespace-nowrap px-6 py-3 rounded-full w-full max-w-[1024px] shadow-lg shadow-black/20">
                <div class="flex items-center gap-3">
                    <div class="size-8 flex items-center justify-center rounded-full bg-primary/20 text-primary">
                        <span class="material-symbols-outlined text-[20px]">task_alt</span>
                    </div>
                    <h2 class="text-white text-lg font-extrabold tracking-tight">TaskMaster</h2>
                </div>
                <div class="hidden md:flex flex-1 justify-center gap-8">
                    <a class="text-slate-300 hover:text-white hover:text-primary transition-colors text-sm font-semibold"
                        href="#">Features</a>
                    <a class="text-slate-300 hover:text-white hover:text-primary transition-colors text-sm font-semibold"
                        href="#">Pricing</a>
                    <a class="text-slate-300 hover:text-white hover:text-primary transition-colors text-sm font-semibold"
                        href="#">About</a>
                </div>
                <div class="flex gap-3">
                    <button
                        class="hidden sm:flex cursor-pointer items-center justify-center rounded-full h-9 px-5 bg-transparent border border-white/20 hover:bg-white/10 text-white text-sm font-bold transition-all">
                        <span><a href="/login">Login</a></span>
                    </button>
                    <button
                        class="flex cursor-pointer items-center justify-center rounded-full h-9 px-5 bg-primary hover:bg-[#3adb0f] text-[#0f172a] text-sm font-bold transition-all shadow-[0_0_15px_rgba(70,236,19,0.3)]">
                        <span> <a href="/register">Get Started</a></span>
                    </button>
                </div>
            </header>
        </div>
    </div>
    <!-- Main Content Wrapper -->
    <div class="flex flex-col min-h-screen">
        <!-- Hero Section -->
        <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden hero-gradient">
            <!-- Background Decorations -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none">
                <div
                    class="absolute top-20 right-0 w-[500px] h-[500px] bg-indigo-600/20 rounded-full blur-[100px] animate-pulse">
                </div>
                <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-primary/10 rounded-full blur-[80px]"></div>
            </div>
            <div class="layout-container flex flex-col items-center px-4 relative z-10">
                <div class="layout-content-container flex flex-col max-w-[1120px] w-full">
                    <div class="@container">
                        <div class="flex flex-col gap-12 lg:gap-20 lg:flex-row items-center">
                            <!-- Hero Text -->
                            <div class="flex flex-col gap-8 flex-1 text-center lg:text-left">
                                <div class="flex flex-col gap-4">
                                    <div
                                        class="inline-flex items-center gap-2 self-center lg:self-start px-3 py-1 rounded-full bg-white/5 border border-white/10 backdrop-blur-sm">
                                        <span class="flex h-3 w-3 rounded-full bg-primary animate-pulse"></span>
                                        <span class="text-xs font-medium text-slate-300 tracking-wide uppercase">V 2.0
                                            is live</span>
                                    </div>
                                    <h1
                                        class="text-white text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.1] tracking-tight">
                                        Manage Your Tasks. <br />
                                        <span class="text-gradient">Simplify Your Life.</span>
                                    </h1>
                                    <h2
                                        class="text-slate-400 text-lg sm:text-xl font-medium leading-relaxed max-w-[600px] mx-auto lg:mx-0">
                                        Experience the future of productivity. Organize workflows, collaborate in
                                        real-time, and achieve your goals with our ultra-modern task engine.
                                    </h2>
                                </div>
                                <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
                                    <button
                                        class="flex min-w-[160px] cursor-pointer items-center justify-center rounded-full h-12 px-8 bg-primary hover:bg-[#3adb0f] text-[#0f172a] text-base font-bold tracking-wide transition-all shadow-[0_0_20px_rgba(70,236,19,0.4)] hover:shadow-[0_0_30px_rgba(70,236,19,0.6)]">
                                        <span class="truncate"><a href="/login">Get Started Free</a></span>
                                    </button>
                                    <button
                                        class="flex min-w-[140px] cursor-pointer items-center justify-center rounded-full h-12 px-8 bg-white/5 border border-white/10 hover:bg-white/10 text-white text-base font-bold tracking-wide transition-all backdrop-blur-sm group">
                                        <span class="truncate flex items-center gap-2">
                                            <a href="/register">start Now</a>
                                            <span
                                                class="material-symbols-outlined text-[20px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                                        </span>
                                    </button>
                                </div>
                                <div class="flex items-center justify-center lg:justify-start gap-4 pt-4">
                                    <div class="flex -space-x-3">
                                        <div class="h-10 w-10 rounded-full border-2 border-[#0f172a] bg-cover bg-center"
                                            data-alt="User avatar 1"
                                            style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuC1UHrezr4-yV3l43CbvRpWXtrq-3sZfV0pNfs-5LIeBNuxsOjbuHoCdhHi4VJQyYZ1nYYqMho6xI8OtZQeQBDz-gdQC49CYvw-vU4DPJmgv2NzBIkeJf-Nz-DHmRv_AOo2v6Glb6Mpsct89C8v7kL828K9hP46XxqpJ_bNUDL-PAtavyHK6B9pfKOnMOOzxEYwWL_TUSccVl-KPfP-9Vy3vIolE6mLcdKiBdCiCz0ntI45pbx4DtK2TahRRWXSRVSBT-ho-hOMFAU");'>
                                        </div>
                                        <div class="h-10 w-10 rounded-full border-2 border-[#0f172a] bg-cover bg-center"
                                            data-alt="User avatar 2"
                                            style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuCUNJJcfRi84Ov2OCdiErDvROhFqfjhl2GzNRFWjTCvTqm47YpkgNOJNj9T1PJN6YgYvUwCh5hl2zjBdFUsaXUYteuJmMJAfKdhX14eNKop951EXZmPiYU_bAgGg0q2ftxrAFtKJgfIY0IS053ctawlm7ScJg0uBoj0_076YITrtBLAMCMjS7eJy6UVW2hlEXRRaXF5lCUIgj-kyv5-pXQ8CeTJV_22XoJkO5FzjRW7ORpXfT3ppRcRqA8uWgGCvSXvrVs0eZChJ4w");'>
                                        </div>
                                        <div class="h-10 w-10 rounded-full border-2 border-[#0f172a] bg-cover bg-center"
                                            data-alt="User avatar 3"
                                            style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuD6B8RhGCcD02a3v7-agzl4exHU06GWK1KkeE6FoBnWsfEqAzmCmhFAysmHesS4eeuGtJD9FZW4ZIoKq81DSQftX7p_JbdlrCR8RxKe5rOhwb_AsPLGCMC625kaOjuxsn1r-grEmdTc6_5D91GXaMrJoOJ7ukuqcBHtVYIRw0itrLDgtiagyzEwqVYEduqoh5f7OBJEjau-hoj9yqJm2g8OpiPqF5bl0r2F7DHh_tyNAc3f3f8OgsstMyJV1j9TFxqEMGxkeQVPgoE");'>
                                        </div>
                                        <div
                                            class="h-10 w-10 rounded-full border-2 border-[#0f172a] bg-slate-700 text-xs font-bold text-white flex items-center justify-center">
                                            2k+</div>
                                    </div>
                                    <p class="text-sm text-slate-400">Trusted by modern teams</p>
                                </div>
                            </div>
                            <!-- Hero Image / Illustration -->
                            <div
                                class="w-full lg:w-1/2 flex justify-center lg:justify-end relative group perspective-1000">
                                <!-- Abstract glow behind image -->
                                <div
                                    class="absolute inset-0 bg-gradient-to-tr from-indigo-500/20 to-purple-500/20 rounded-3xl blur-2xl transform rotate-3 scale-95 opacity-70">
                                </div>
                                <div class="relative w-full aspect-square max-w-[500px] lg:max-w-none bg-slate-800/50 rounded-3xl border border-white/10 shadow-2xl overflow-hidden backdrop-blur-sm transition-transform duration-500 hover:rotate-1 hover:scale-[1.02]"
                                    data-alt="Abstract 3D dashboard interface showing task cards, progress bars, and floating collaborative user bubbles in a dark mode setting">
                                    <!-- Decorative interior simulating a UI -->
                                    <div
                                        class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1611162617474-5b21e879e113?q=80&amp;w=1000&amp;auto=format&amp;fit=crop')] bg-cover bg-center opacity-40 mix-blend-overlay">
                                    </div>
                                    <div
                                        class="absolute inset-0 bg-gradient-to-t from-[#0f172a] via-transparent to-transparent">
                                    </div>
                                    <!-- Simulated UI Elements -->
                                    <div class="absolute top-8 left-8 right-8 flex flex-col gap-4">
                                        <div class="flex items-center justify-between">
                                            <div class="h-3 w-24 bg-white/20 rounded-full"></div>
                                            <div
                                                class="h-8 w-8 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                                                <span class="material-symbols-outlined text-sm">notifications</span>
                                            </div>
                                        </div>
                                        <div
                                            class="h-32 w-full bg-white/5 rounded-xl border border-white/5 p-4 flex flex-col justify-between backdrop-blur-md hover:bg-white/10 transition-colors">
                                            <div class="flex justify-between items-start">
                                                <div
                                                    class="h-8 w-8 rounded bg-indigo-500/30 flex items-center justify-center text-indigo-300">
                                                    <span class="material-symbols-outlined text-sm">auto_awesome</span>
                                                </div>
                                                <span class="text-xs text-white/40">Now</span>
                                            </div>
                                            <div class="space-y-2">
                                                <div class="h-4 w-3/4 bg-white/80 rounded"></div>
                                                <div class="h-2 w-1/2 bg-white/20 rounded"></div>
                                            </div>
                                        </div>
                                        <div class="flex gap-4">
                                            <div
                                                class="h-24 flex-1 bg-white/5 rounded-xl border border-white/5 p-3 backdrop-blur-md">
                                            </div>
                                            <div
                                                class="h-24 flex-1 bg-white/5 rounded-xl border border-white/5 p-3 backdrop-blur-md">
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Floating Element -->
                                    <div
                                        class="absolute -bottom-6 -right-6 h-32 w-32 bg-gradient-to-br from-primary to-green-600 rounded-2xl shadow-xl flex items-center justify-center text-black font-bold text-4xl rotate-12 z-20">
                                        <span class="material-symbols-outlined text-5xl text-[#0f172a]">check</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- Feature Section -->
        <section id="about" class="relative py-24 bg-[#0f172a]">
            <div class="layout-container flex justify-center px-4">
                <div class="layout-content-container flex flex-col max-w-[1120px] w-full">
                    <div class="flex flex-col gap-16">
                        <!-- Header -->
                        <div class="flex flex-col gap-4 text-center items-center">
                            <h2 class="text-primary font-bold tracking-wider uppercase text-sm">Why TaskMaster?</h2>
                            <h3
                                class="text-white text-3xl md:text-4xl lg:text-5xl font-black tracking-tight max-w-[800px]">
                                Powerful Features for Modern Teams
                            </h3>
                            <p class="text-slate-400 text-lg max-w-[600px]">
                                Everything you need to manage complex workflows with ease and style.
                            </p>
                        </div>
                        <!-- Cards Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <!-- Card 1 -->
                            <div
                                class="group glass-panel rounded-2xl p-8 hover:bg-white/5 transition-all duration-300 hover:-translate-y-1">
                                <div
                                    class="h-14 w-14 rounded-2xl bg-indigo-500/20 text-indigo-300 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                                    <span class="material-symbols-outlined text-[32px]">insights</span>
                                </div>
                                <div class="flex flex-col gap-3">
                                    <h4 class="text-white text-xl font-bold">Smart Task Tracking</h4>
                                    <p class="text-slate-400 leading-relaxed">AI-driven insights analyze your daily
                                        workflow patterns to suggest optimizations and predict project timelines.</p>
                                </div>
                            </div>
                            <!-- Card 2 -->
                            <div
                                class="group glass-panel rounded-2xl p-8 hover:bg-white/5 transition-all duration-300 hover:-translate-y-1 relative overflow-hidden">
                                <!-- Subtle highlight for middle card -->
                                <div
                                    class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2">
                                </div>
                                <div
                                    class="h-14 w-14 rounded-2xl bg-primary/20 text-primary flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                                    <span class="material-symbols-outlined text-[32px]">check_circle</span>
                                </div>
                                <div class="flex flex-col gap-3 relative z-10">
                                    <h4 class="text-white text-xl font-bold">Priority Management</h4>
                                    <p class="text-slate-400 leading-relaxed">Focus on what matters most. Our Eisenhower
                                        matrix implementation automatically sorts tasks by urgency.</p>
                                </div>
                            </div>
                            <!-- Card 3 -->
                            <div
                                class="group glass-panel rounded-2xl p-8 hover:bg-white/5 transition-all duration-300 hover:-translate-y-1">
                                <div
                                    class="h-14 w-14 rounded-2xl bg-purple-500/20 text-purple-300 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                                    <span class="material-symbols-outlined text-[32px]">admin_panel_settings</span>
                                </div>
                                <div class="flex flex-col gap-3">
                                    <h4 class="text-white text-xl font-bold">Secure Authentication</h4>
                                    <p class="text-slate-400 leading-relaxed">Enterprise-grade security protocols with
                                        MFA and end-to-end encryption ensure your data stays private.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- Footer -->
         <%- include('./partials/footer') %>
    </div>
</body>

</html>